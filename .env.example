# ─── Server ───────────────────────────────────
PORT=3000
NODE_ENV=production
SITE_URL=https://voice.mybots.in

# ─── TTS API (plug in whichever you use) ──────
# Option 1: Microsoft Azure Cognitive Services
AZURE_TTS_KEY=your_azure_key_here
AZURE_TTS_REGION=eastus

# Option 2: ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Option 3: Google Cloud TTS
GOOGLE_TTS_KEY=your_google_key_here

# Option 4: PlayHT
PLAYHT_API_KEY=your_playht_key_here
PLAYHT_USER_ID=your_playht_user_id_here

# ─── Active provider ──────────────────────────
# Values: azure | elevenlabs | google | playht | browser
TTS_PROVIDER=azure

# ─── Rate limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# ─── Cache ────────────────────────────────────
CACHE_TTL_SECONDS=3600
